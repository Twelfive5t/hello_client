{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "client_release",
            "displayName": "Release Client Base",
            "description": "Base configuration",
            "generator": "Ninja",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_INSTALL_PREFIX": "products",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "CMAKE_POLICY_DEFAULT_CMP0077": "NEW",
                "CMAKE_POLICY_DEFAULT_CMP0091": "NEW",
                "CMAKE_BUILD_TYPE": "Release"
            },
            "toolchainFile": "${sourceDir}/build/Release/generators/conan_toolchain.cmake",
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "client_release_x64",
            "displayName": "Release Client x64 Build Release",
            "description": "Release build for x64 architecture",
            "inherits": "client_release",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        },
        {
            "name": "client_release_x86",
            "displayName": "Release Client x86 Build Release",
            "description": "Release build for x86 architecture",
            "inherits": "client_release",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "client_release_x64",
            "configurePreset": "client_release_x64",
            "jobs": 16
        },
        {
            "name": "client_release_x86",
            "configurePreset": "client_release_x86",
            "jobs": 16
        }
    ]
}
